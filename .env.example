# @BotFather dan olingan token
BOT_TOKEN=123456789:ABC...

# Admin Telegram user ID (raqam). Bir nechta bo'lsa vergul bilan: 111111,222222
# O'zingizni ID ni @userinfobot yoki @getidsbot orqali bilishingiz mumkin
ADMIN_IDS=123456789

# --- Heroku ---
# .env fayl Herokuda ISHLATILMAYDI. Dashboard → Settings → Config Vars ga
# BOT_TOKEN va ADMIN_IDS ni qo'lda qo'shing yoki:
#   heroku config:set BOT_TOKEN="..." -a APP_NOMI
#   heroku config:set ADMIN_IDS="..." -a APP_NOMI
